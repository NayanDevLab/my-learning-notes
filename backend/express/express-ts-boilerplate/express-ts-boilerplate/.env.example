# ── Application ──────────────────────────────────────────────
# development | production | test
NODE_ENV=development
PORT=3000

# ── Logging ─────────────────────────────────────────────────
# fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Rate limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Example of a REQUIRED variable ──────────────────────────
# Uncomment the matching line in src/config/env.ts to enforce it.
# The app will refuse to start if a required variable is missing.
# DATABASE_URL=postgres://user:password@localhost:5432/mydb
